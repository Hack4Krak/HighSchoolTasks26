<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/IntroFragment">

    <fragment
        android:id="@+id/IntroFragment"
        android:name="pl.hack4krak.androidtask.IntroFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_intro">

        <action
            android:id="@+id/action_IntroFragment_to_QuestionnaireFragment"
            app:destination="@id/QuestionnaireFragment"
            app:popUpTo="@id/IntroFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/QuestionnaireFragment"
        android:name="pl.hack4krak.androidtask.QuestionnaireFragment"
        android:label="@string/app_name"
        tools:layout="@layout/fragment_questionnaire" />
</navigation>
